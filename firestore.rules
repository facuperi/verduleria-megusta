rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isGerente() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'gerente';
    }

    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isGerente());
      allow write: if isGerente();
    }

    match /productos/{productoId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /ventas/{ventaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isGerente();
    }

    match /caja/{cajaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth()
        && resource.data.abiertoPor == request.auth.uid
        && resource.data.estado == 'abierta';
      allow delete: if false;
    }

    match /retirosCaja/{retiroId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /movimientosStock/{movimientoId} {
      allow read, write: if isGerente();
    }

    match /tiposRetiro/{tipoId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isGerente();
    }
  }
}
